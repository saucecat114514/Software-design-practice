# —— 机密：API 密钥 / 凭证，绝对不能提交到 GitHub ——
.env
.env.*
!.env.example
*.key
*.pem
secrets/
**/凭证/

# —— 云盘式仓库：尽量少排除，只挡掉真正的噪音文件 ——

# Node 依赖（compile.js 若引入第三方包时产生）
node_modules/

# Python 字节码缓存
__pycache__/
*.pyc

# 对话页面运行态会话缓存（恢复用，非交付物）
wiki/summaries/agents/web/sessions/

# SRS 分章中间产物（最终拼装为 SRS-初稿，分章不入库避免重复）
wiki/summaries/srs_parts/

# Office / WPS 打开文档时生成的临时锁文件（如 ~$讲义.docx）
~$*

# 操作系统垃圾文件
Thumbs.db
desktop.ini
.DS_Store

# 编辑器 / IDE 配置
.vscode/
.idea/
.obsidian/
*.swp

# 临时文件
*.tmp
*.log

# Java / Maven 构建产物（v1/v2 代码工程，源码入库、产物不入库）
target/
*.class
*.jar
!**/maven-wrapper.jar

# 提交包构建产物（由 git archive 从 HEAD 生成，无需入库）
*.zip

# 成果展示页（本地预览/演示用，不入库）
期中成果展示.html
